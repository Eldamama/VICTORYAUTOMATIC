/* DESIGN UNILINK - STRATÉGIE ORGANIQUE */
body {
    background-color: #0a0a0b;
    color: #ffffff;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    margin: 0;
    display: flex;
    justify-content: center;
    padding: 20px;
}

.container {
    max-width: 400px;
    width: 100%;
}

/* LOGO */
.logo-container {
    text-align: center;
    padding: 10px 0 20px 0;
}

.logo-text {
    font-size: 32px;
    font-weight: bold;
    letter-spacing: 2px;
    color: #1e3a8a; /* Bleu Roi */
    text-transform: uppercase;
}

.logo-gold {
    color: #d4af37; /* Or */
}

/* CARTES ET SECTIONS */
.status-card, .step-card, .info-box {
    background: #161618;
    border-radius: 15px;
    padding: 20px;
    margin-bottom: 20px;
    border: 1px solid #222;
}

.status-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-left: 5px solid #1e3a8a;
}

.status-inactive { color: #ef4444; font-weight: bold; margin: 0; }
.status-active { color: #10b981; font-weight: bold; margin: 0; }

.timer-box { text-align: right; }
#countdown { font-family: monospace; font-size: 18px; color: #d4af37; }

/* ÉTAPES */
.step-badge {
    background: #1e3a8a;
    color: white;
    width: 25px;
    height: 25px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 14px;
    margin-bottom: 10px;
}

.hidden { display: none; }

/* BOUTONS ET INPUTS */
.btn-primary {
    background: #1e3a8a;
    color: white;
    border: none;
    padding: 15px;
    width: 100%;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

.btn-primary:hover { opacity: 0.9; }

.btn-gold {
    background: #d4af37;
    color: #000;
    border: none;
    padding: 18px;
    width: 100%;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
}

.btn-gold:hover { opacity: 0.9; }

.btn-whatsapp {
    background: #25D366;
    color: white;
    border: none;
    padding: 15px;
    width: 100%;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}

button:disabled {
    background: #333 !important;
    color: #888 !important;
    cursor: not-allowed;
    box-shadow: none;
}

.input-field {
    background: #222;
    color: white;
    border: 1px solid #444;
    outline: none;
    padding: 10px;
    border-radius: 6px;
    width: 100%;
    margin-top: 10px;
}

/* NOTIFICATIONS */
.toast {
    position: fixed;
    top: 20px;
    background: #1e3a8a;
    padding: 10px 20px;
    border-radius: 5px;
    display: none;
    z-index: 1000;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    color: white;
}